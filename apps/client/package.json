{
     "name": "@app/client",
     "private": true,
     "version": "0.0.0",
     "type": "module",
     "scripts": {
       "dev": "vite",
       "dev:force": "vite --force",
       "build": "tsc -b && vite build",
       "build:vercel": "npm install && npm run build",
       "build:analyze": "ANALYZE=true vite build",
       "analyze": "npm run build:analyze",
       "typecheck": "tsc -b --noEmit",
       "typecheck:watch": "tsc -b --watch --noEmit",
       "lint": "eslint .",
       "lint:fix": "eslint . --fix",
       "preview": "vite preview",
       "test": "vitest run",
       "test:watch": "vitest",
       "test:coverage": "vitest run --coverage",
       "test:e2e": "playwright test",
       "test:e2e:ui": "playwright test --ui",
       "test:e2e:debug": "playwright test --debug",
       "test:performance": "playwright test performance.spec.ts --project=chromium",
       "test:smoke": "playwright test smoke.spec.ts --project=chromium",
       "clean": "rm -rf dist .turbo node_modules/.vite",
       "playwright:install": "playwright install",
       "playwright:report": "playwright show-report",
       "lighthouse": "lhci autorun",
       "lighthouse:ci": "lhci autorun --failOnUploadFailure",
       "bundle:analyze": "npm run build:analyze && npx serve dist -p 8080 &",
       "perf:audit": "npm run build && npm run lighthouse",
       "storybook": "storybook dev -p 6006",
       "build-storybook": "storybook build"
     },
